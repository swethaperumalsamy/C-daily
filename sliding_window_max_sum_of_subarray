#include<stdio.h>
int maxSum(int n,int arr[],int k)
{
    int sum=0;
    for(int i=0;i<k;i++)
    {
        sum=sum+arr[i];
    }
    int max=sum;
    for(int i=k;i<n;i++)
    {
        sum=sum-arr[i-k]+arr[i];
        if(sum>max)
        max=sum;
    }
    return max;
}
int main()
{
    int n,k;
    scanf("%d",&n);
    int arr[n];
    for(int i=0;i<n;i++){
    scanf("%d",&arr[i]);}
    scanf("%d",&k);
    int result=maxSum(n,arr,k);
    printf("%d",result);
}
