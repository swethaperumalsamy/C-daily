#include <stdio.h>

int main() {
    int n;
    printf("Enter number of rows: ");
    scanf("%d", &n);

    for (int i = 1; i <= n; i++) {
        int num = 1;

        // spaces for pyramid shape
        for (int s = 1; s <= n - i; s++)
            printf("  ");

        // Pascal triangle numbers
        for (int j = 1; j <= i; j++) {
            printf("%4d", num);
            num = num * (i - j) / j;
        }

        printf("\n");
    }

    return 0;
}


